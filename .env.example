# Supabase (cliente - VITE_ vai pro bundle do navegador)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Anthropic (server-side, usado pelo proxy /api/analyze-guia)
# NÃO usa prefixo VITE_ - chave fica só no servidor (Vercel env var)
# Para rodar localmente com `vercel dev`, configure também aqui:
ANTHROPIC_API_KEY=sk-ant-...
